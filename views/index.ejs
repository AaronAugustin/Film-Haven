<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title><%= title %></title>

    <link rel="icon" href="/assets/icons/video_camera_icon.webp"/>

    <link rel="stylesheet" href="/stylesheets/home.css" type="text/css">
    <link rel="stylesheet" href="/stylesheets/elements/fonts.css" type="text/css">
    <link rel="stylesheet" href="/stylesheets/elements/movie-card.css" type="text/css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=search" />

    <script src="/javascripts/elements/logo.js"></script>
    <script src="/javascripts/elements/lang-select.js"></script>
    <script src="/javascripts/elements/prototype-btn.js"></script>
  
    <script src="/javascripts/users/login-system.js"></script>
    
    <script type="module" src="/javascripts/api/utils.js"></script>
  
    <script type="module" src="/javascripts/frontend/home.js"></script>
    <script type="module" src="/javascripts/frontend/genres.js"></script>
    
  
</head>
<body>
    <nav class="navbar">
      
    <div class="navbar-left">
      <div class="logo">Film Haven</div>
    </div>

    <h3>A site by Jerome Foster & Aaron Augustin.</h3>

    <div class="navbar-right">
      <button id="login-btn">Sign In</button>
      <button id="logout-btn">Logout</button>
      <button id="prototype-btn">Prototype</button>

      <select class="lang-select" onchange="changeLanguage(this.value)">
        <option value="" selected>EN</option>
        <option value="es">ES</option>
      </select>
    </div>
  </nav>

  <br> <br>

  <div class="now-playing__container">
    <section class="now-playing__text">
      <h2>Latest Movie Releases</h2>
    </section>

    <section class="now-playing__images">
      <div id="lastest-movies">
         <!-- images will show dynamically -->
      </div>
    </section>
  </div>

  <div class="saved-movies__container">
    <section class="saved-movies__text">
      <h2>Your Watchlist (saved movies)</h2>
    </section>

    <section class="saved-movies__images">
      <div id="watchlist">
        <!-- images will show dynamically -->
      </div>
    </section>
  </div>

  <div class="genre__container">
    <section class="genre__text">
      <h2>Select A Movie Genre Here: <input list="genre-list" placeholder="Pick A Genre" name="genre-list"> <button id="select">Gimmie Movies!</button></h2>
      <datalist id="genre-list">
        <option data-value="" value="Action">Action</option>
        <option data-value="" value="Adventure">Adventure</option>
        <option data-value="" value="Animation">Animation</option>
        <option data-value="" value="Comedy">Comedy</option>
        <option data-value="" value="Crime">Crime</option>
        <option data-value="" value="Documentary">Documentary</option>
        <option data-value="" value="Drama">Drama</option>
        <option data-value="" value="Family">Family</option>
        <option data-value="" value="Fantasy">Fantasy</option>
        <option data-value="" value="History">History</option>
        <option data-value="" value="Horror">Horror</option>
        <option data-value="" value="Music">Music</option>
        <option data-value="" value="Mystery">Mystery</option>
        <option data-value="" value="Romance">Romance</option>
        <option data-value="" value="Science Fiction">Science Fiction</option>
        <option data-value="" value="TV Movie">TV Movie</option>
        <option data-value="" value="Thriller">Thriller</option>
        <option data-value="" value="War">War</option>
        <option data-value="" value="Western">Western</option>
        <option data-value="" value="Clear">Clear</option>
      </datalist>
    </section>

    <section class="genre__images">
      <div id="scrolling-genres">
        <!-- images will show dynamically -->
      </div>
    </section>
  </div>
</body>
</html>