
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="icon" href="/assets/icons/video_camera_icon.webp"/>
  <link rel="stylesheet" href="/stylesheets/home.css" type="text/css">
  <link rel="stylesheet" href="/stylesheets/elements/fonts.css" type="text/css">
  <link rel="stylesheet" href="/stylesheets/elements/movie-card.css" type="text/css">
  <link rel="stylesheet" href="/stylesheets/movie-details.css" type="text/css">
</head>
<body>
  <nav class="navbar">
    <div class="navbar-left">
      <div class="logo" onclick="window.location.href='/'">Film Haven</div>
    </div>
    <div class="navbar-right">
      <select class="lang-select" id="langSelect" onchange="changeLanguage(this.value)">
        <option value="">EN</option>
        <option value="es" selected>ES</option>
      </select>
      <button id="login-btn" style="display: none;">Iniciar Sesión</button>
      <button id="logout-btn" style="display: none;">Cerrar Sesión</button>
    </div>
  </nav>

  <main>
    <div id="movie-details-container">
      <!-- Movie details will be loaded here -->
    </div>
  </main>

  <script type="module" src="/javascripts/frontend/movie-details.js"></script>
  <script src="/javascripts/users/login-system.js"></script>
  <script>
    // Pass the movie ID to the frontend script
    window.movieId = '<%= movieId %>';
    
    function changeLanguage(lang) {
      const currentPath = window.location.pathname;
      if (lang === 'es') {
        // Already on Spanish page, do nothing
        return;
      } else {
        // Switch to English
        const movieId = '<%= movieId %>';
        window.location.href = `/movie/${movieId}`;
      }
    }
  </script>
</body>
</html>
